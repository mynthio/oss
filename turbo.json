{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["MYNTH_WORKOS_CLIENT_ID"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "//#lint": {},
    "//#lint:fix": {
      "cache": false
    },
    "//#format:check": {},
    "//#format:fix": {
      "cache": false
    }
  }
}
