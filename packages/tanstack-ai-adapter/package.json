    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@tanstack/ai": ">=0.9.2"
  }
