{
  "name": "@mynthio/sdk",
  "version": "0.0.6",
  "description": "Official Mynth SDK for image generation",
  "keywords": [
    "ai",
    "image-generation",
    "mynth",
    "sdk"
  ],
  "homepage": "https://mynth.io",
  "license": "MIT",
  "author": "mynth.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/mynthio/oss",
    "directory": "packages/sdk"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./convex": {
      "types": "./dist/convex/index.d.ts",
      "import": "./dist/convex/index.js",
      "default": "./dist/convex/index.js"
    }
  },
  "scripts": {
    "build": "bun run build:clean && bun run build:js && bun run build:types",
    "build:clean": "rm -rf dist",
    "build:js": "bun build ./src/index.ts ./src/convex/index.ts --outdir ./dist --format esm --splitting --target bun --minify --packages external",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "convex": "^1.32.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "convex": "^1.27.3"
  },
  "peerDependenciesMeta": {
    "convex": {
      "optional": true
    }
  }
}
