{
  "name": "@mynthio/tanstack-ai-adapter",
  "version": "0.0.8",
  "description": "Mynth image generation adapter for TanStack AI",
  "keywords": [
    "adapter",
    "ai",
    "image-generation",
    "mynth",
    "tanstack"
  ],
  "license": "MIT",
  "author": "mynth.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/mynthio/oss",
